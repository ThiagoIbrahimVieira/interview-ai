# Application
APP_NAME=AI Interview Platform
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_ORIGINS=["http://localhost:8000","http://localhost:3000","http://localhost:8080"]

# Database
# SQLite for development (no external DB needed)
DATABASE_URL=sqlite+aiosqlite:///./ai_interview.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_interview
DATABASE_ECHO=false

# JWT
JWT_SECRET_KEY=change-me-to-another-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_AI_PER_MINUTE=20

# Brute Force Protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# Input Validation
MAX_INPUT_LENGTH=5000
MAX_CUSTOM_INSTRUCTIONS_LENGTH=2000
MAX_PER_PAGE=50

# Logging
LOG_LEVEL=INFO
