# Application
APP_NAME=AI Interview Platform
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_ORIGINS=["http://localhost:8000","http://localhost:3000","http://localhost:8080"]

# Database
# SQLite for development (no external DB needed)
DATABASE_URL=sqlite+aiosqlite:///./ai_interview.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_interview
DATABASE_ECHO=false

# JWT
JWT_SECRET_KEY=change-me-to-another-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
